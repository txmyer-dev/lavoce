{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lavoce",
  "version": "0.1.0",
  "identifier": "app.felaniam.lavoce",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/voicebox-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "title": "Lavoce",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true,
        "userAgent": null,
        "titleBarStyle": "Overlay"
      }
    ],
    "withGlobalTauri": true
  },
  "plugins": {
    "shell": {
      "open": ".*"
    }
  }
}
