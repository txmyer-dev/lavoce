# Copy to .env for local development. Do not commit real secrets.

# Microsoft Speech to Text (Azure AI Speech fast transcription)
VOICEBOX_MICROSOFT_STT_ENDPOINT=https://your-speech-resource.cognitiveservices.azure.com
VOICEBOX_MICROSOFT_STT_KEY=your-speech-resource-key
VOICEBOX_MICROSOFT_STT_LOCALE=en-US
VOICEBOX_MICROSOFT_STT_PROFANITY=None

# FreeLLMAPI refinement
# Local Docker Compose can use host.docker.internal because docker-compose.yml
# adds the host-gateway alias. Dokploy/Swarm on this host can use
# http://172.16.1.1:3001/v1/chat/completions instead.
VOICEBOX_FREELLMAPI_URL=http://host.docker.internal:3001/v1/chat/completions
VOICEBOX_FREELLMAPI_KEY=freellmapi-your-key
VOICEBOX_FREELLMAPI_MODEL=auto
